{
  "name": "DailyDevotional",
  "type": "object",
  "properties": {
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date of devotional"
    },
    "verse_reference": {
      "type": "string",
      "description": "Bible verse reference (e.g., John 3:16)"
    },
    "verse_text": {
      "type": "string",
      "description": "The verse text"
    },
    "reflection": {
      "type": "string",
      "description": "AI-generated devotional reflection"
    },
    "theme": {
      "type": "string",
      "description": "Daily theme or topic"
    }
  },
  "required": ["date", "verse_reference", "verse_text", "reflection"]
}
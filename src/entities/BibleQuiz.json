{
  "name": "BibleQuiz",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Quiz title"
    },
    "passage_reference": {
      "type": "string",
      "description": "Bible passage reference (e.g., John 3:16)"
    },
    "passage_text": {
      "type": "string",
      "description": "Full passage text"
    },
    "topic": {
      "type": "string",
      "description": "Topic or theme"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "question": {"type": "string"},
          "options": {
            "type": "array",
            "items": {"type": "string"}
          },
          "correct_answer": {"type": "number"},
          "explanation": {"type": "string"}
        }
      },
      "description": "Quiz questions with options"
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"],
      "default": "medium"
    },
    "created_by": {
      "type": "string",
      "description": "Email of creator"
    }
  },
  "required": ["title", "passage_reference", "questions"]
}
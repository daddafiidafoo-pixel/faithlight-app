{
  "name": "SharedReadingGoal",
  "type": "object",
  "properties": {
    "groupId": {
      "type": "string",
      "description": "Reference to StudyGroup"
    },
    "title": {
      "type": "string",
      "description": "Goal title"
    },
    "startDate": {
      "type": "string",
      "format": "date",
      "description": "Goal start date"
    },
    "endDate": {
      "type": "string",
      "format": "date",
      "description": "Goal end date"
    },
    "passages": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Passages to read"
    },
    "completedByEmails": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Emails of members who completed"
    },
    "createdBy": {
      "type": "string",
      "description": "Email of goal creator"
    }
  },
  "required": ["groupId", "title", "startDate", "endDate", "passages", "createdBy"]
}